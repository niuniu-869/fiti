    },
    {
      "id": "q22",
      "dims": ["SOCIAL", "BOUNDARY"],
      "text": "同事请你帮忙朋友圈点赞，你发现那是微商广告。你会？",
      "options": [
        { "label": "点了，但设为不可见", "value": 2 },
        { "label": "点了，以后屏蔽他", "value": 1 },
        { "label": "直接说「不太方便」", "value": 3 }
