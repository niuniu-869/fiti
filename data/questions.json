    {
      "id": "q25",
      "dims": ["STRATEGY", "EXECUTE"],
      "text": "你想养成一个新习惯，比如每天读书。你会？",
      "options": [
        { "label": "有空就读，不强迫", "value": 1 },
        { "label": "定具体时间地点，加入日程", "value": 3 },
        { "label": "每天提醒自己读几页", "value": 2 }
