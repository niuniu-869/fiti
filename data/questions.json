  "special": [
    {
      "id": "wealth_gate",
      "special": true,
      "kind": "wealth_gate",
      "text": "朋友聚餐结账时，你通常会？",
      "options": [
        { "label": "等别人先开口，或者尽量少付", "value": 1 },
        { "label": "主动买单，或者轮流请客", "value": 3 },
        { "label": "AA，或者看情况", "value": 2 }
